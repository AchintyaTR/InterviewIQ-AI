# Database Config
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interview_iq

# API Authentication Security Keys
JWT_SECRET_KEY=generate_high_entropy_32_byte_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# External LLM Engine Keys
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vector Store Configurations
VECTOR_DB_URL=http://localhost:8001
VECTOR_DB_COLLECTION_NAME=interview_questions

# Audio Processing API Parameters
SPEECH_STORAGE_PATH=./data/audio
AUDIO_FORMAT=wav

# Next.js Port Settings
PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
